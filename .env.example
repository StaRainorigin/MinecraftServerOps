# MC-SRE 配置文件模板
# 复制为 .env 并填入实际值：cp .env.example .env

# ──────────── CurseForge ────────────
# CurseForge Core API Key（必填！没有 Key 则 CF mod 下载会受 CDN 限速）
# 申请地址：https://console.curseforge.com → 注册 → 创建项目 → 获取 API Key
CF_API_KEY=

# ──────────── 下载 ────────────
# 全局下载并发数（默认 32）
# DOWNLOAD_CONCURRENCY=32
# 单个 URL 下载超时秒数（默认 30）
# DOWNLOAD_TIMEOUT=30

# ──────────── Java ────────────
# Java 路径（空=自动探测，MC 1.21+ 自动要求 Java 21+）
# JAVA_PATH=
# 最低 Java 版本（0=不限）
# JAVA_MIN_VERSION=0

# ──────────── 路径 ────────────
# 构建沙箱目录
# SANDBOX_DIR=.sandbox
# 服务端交付池目录
# SERVER_POOL_DIR=server_pool
# 下载缓存目录
# CACHE_DIR=.cache
